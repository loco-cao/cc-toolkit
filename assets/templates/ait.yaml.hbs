name: {{name}}
version: 0.1.0
description: >
  {{description}}

argument-hint: "{{argumentHint}}"

targets:
  claude:
    trigger: /{{name}}
    path: claude/SKILL.md
  codex:
    trigger: /{{name}}
    path: codex/SKILL.md

# ── ai-terminal protocol ──────────────────────
# output_dir:  where the skill writes session data (discovered by ai-terminal)
# report_pattern: glob for per-agent report files (e.g. "*/report.json")
# global_timeout: max execution time in seconds
# agent_timeout:  per-agent timeout in seconds (reserved, not yet enforced by ai-terminal)
output_dir: .ait-skill
report_pattern: "*/report.json"
global_timeout: 600
agent_timeout: 120

# Optional: custom interactive prompts (example)
# prompts:
#   - name: mode
#     type: select
#     message: "Choose mode"
#     options:
#       - label: Remote
#         value: "--remote"
#       - label: Local
#         value: "--local"
